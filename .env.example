# Appwrite API Endpoint and Project ID
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=your_project_id_here

# Appwrite Database and Collection IDs
VITE_APPWRITE_DATABASE_ID=your_database_id_here
VITE_APPWRITE_AGENCY_PROFILE_COLLECTION_ID=your_agency_profile_collection_id_here
VITE_APPWRITE_CASE_STUDIES_COLLECTION_ID=your_case_studies_collection_id_here
VITE_APPWRITE_CLIENT_LEADS_COLLECTION_ID=your_client_leads_collection_id_here

# Appwrite Storage Bucket ID (For profile avatars and case study thumbnails)
VITE_APPWRITE_STORAGE_BUCKET_ID=your_storage_bucket_id_here
